# PaceGuard runs without environment variables using seeded fictional data.

# Optional production athlete-memory provider
QDRANT_URL=
QDRANT_API_KEY=

# Hosted Lyzr agent (server-side only)
LYZR_API_URL=https://agent-prod.studio.lyzr.ai/v3/inference/chat/
LYZR_API_KEY=
LYZR_AGENT_ID=
LYZR_USER_ID=

# InsForge Postgres + Realtime (public values are safe for browser use with RLS)
INSFORGE_BASE_URL=
INSFORGE_ANON_KEY=
NEXT_PUBLIC_INSFORGE_BASE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Optional production wearable OAuth adapters
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Optional Zero agent capability session (server-side only)
ZERO_SESSION_TOKEN=
ZERO_MAX_PAY_USDC=0.25

# Optional notification delivery provider for athlete invitations
RESEND_API_KEY=

# Required before storing real athlete data in a production database
DATABASE_URL=
AUTH_SECRET=
