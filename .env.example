# PaceGuard runs without environment variables using seeded fictional data.

# Optional production athlete-memory provider
QDRANT_URL=
QDRANT_API_KEY=

# Future hosted Lyzr workflow adapter
LYZR_API_URL=
LYZR_API_KEY=
LYZR_WORKFLOW_ID=

# Optional production wearable OAuth adapters
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Optional Zero agent capability session (server-side only)
ZERO_SESSION_TOKEN=
ZERO_MAX_PAY_USDC=0.25
